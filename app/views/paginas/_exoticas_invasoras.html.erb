<%
  totales = @totales
  resultados = @tabla_exoticas[:datos].count
  por_pagina = @por_pagina
  comienzo = por_pagina*(@pagina-1) + 1
  final = comienzo + resultados - 1
%>

<% @tabla_exoticas[:datos].each do |row| %>
  <tr>
    <%# Foto %>
    <td><%= image_tag(row[0], class: 'img rounded', style: "width: 10em") if row[0].present? %></td>
    
    <%# Nombre científico %>
    <td>
      <% if row[1].present? %>
        <% if row[1].is_a?(String) %>
          <%= row[1] %>
        <% else %>
          <%= link_to row[1].nombre_cientifico, especie_path(row[1]), target: :_blank %>
        <% end %>
      <% else %>
        <em>Nombre no disponible</em>
      <% end %>
    </td>
    
    <%# Familia %>
    <td><%= row[2] %></td>
    
    <%# Grupo %>
    <td><%= row[3] %></td>
    
    <%# Ambiente %>
    <td><%= row[4] %></td>
    
    <%# Origen %>
    <td><%= row[5] %></td>
    
    <%# Presencia %>
    <td><%= row[6] %></td>
    
    <%# Estatus %>
    <td><%= row[7] %></td>
    
    <%# Rutas de Introducción (sin prefijo Ruta_) %>
    <td>
      <% if row[12].present? %>
        <%= row[12].gsub(/Ruta_/, '') %>
      <% end %>
    </td>
    
    <%# Análisis de riesgo (Ficha) - Solo mostrar si hay MERI o Extenso %>
    <td>
      <% if row[11].present? && row[11].is_a?(Array) && row[11].any? %>
        <% row[11].each do |pdf_info| %>
          <% if pdf_info[:encontrado] && (pdf_info[:tipo] == 'MERI' || pdf_info[:tipo] == 'Extenso') %>
            <%= link_to pdf_info[:tipo], pdf_info[:ruta], target: :_blank, 
                class: "btn btn-sm #{pdf_info[:tipo] == 'MERI' ? 'btn-success' : 'btn-warning'} mr-1 mb-1" %>
          <% end %>
        <% end %>
      <% end %>
    </td>
    
    <%# Acuerdo SEMARNAT (columna vacía por ahora) %>
    <td></td>
    
    <%# Instrumento legal - Manteniendo (género) con encoding correcto %>
    <td>
      <% if row[10].present? && row[10].is_a?(Array) %>
        <% row[10].each do |instrumento| %>
          <% if instrumento[:pdf].present? %>
            <%= link_to instrumento[:nombre], instrumento[:pdf], target: :_blank, class: "d-block small" %>
          <% else %>
            <span class="text-muted small"><%= instrumento[:nombre] %></span>
          <% end %>
        <% end %>
      <% end %>
    </td>
  </tr>
<% end %>

<script>
  $('#num-res-exoticas').html("Mostrando del <%= comienzo %> al <%= final %> de <%= totales %> resultados");
</script>